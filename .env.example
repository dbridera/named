# Named Configuration
# Copy this file to .env and fill in your values

# Required: API key (works for both OpenAI and Azure AI Foundry)
NAMED_OPENAI_API_KEY=sk-proj-your-key-here

# Optional: Model or deployment name (default: gpt-4o)
# For Azure AI Foundry, use your deployment name instead of the model name.
NAMED_OPENAI_MODEL=gpt-4o

# Optional: Custom base URL for Azure AI Foundry or other OpenAI-compatible APIs.
# For Azure AI Foundry, use one of:
#   https://YOUR-RESOURCE.openai.azure.com/openai/v1/
#   https://YOUR-RESOURCE.services.ai.azure.com/openai/v1/
# Leave empty or unset to use OpenAI directly.
# NAMED_OPENAI_BASE_URL=

# --- Azure Workload Identity (AKS with azure.workload.identity/use: "true") ---
# When set, API key is ignored; auth uses Managed Identity token.
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_CLIENT_ID=your-managed-identity-client-id
# Optional: deployment for Batch API (SKU globalbatch). If set, batch mode uses this.
# AZURE_OPENAI_BATCH_DEPLOYMENT_NAME=gpt-4o-batch-v1

# Optional: Minimum confidence threshold for suggestions (default: 0.80)
NAMED_CONFIDENCE_THRESHOLD=0.80

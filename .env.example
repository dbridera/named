# Named Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API key
NAMED_OPENAI_API_KEY=sk-proj-your-key-here

# Optional: OpenAI model to use (default: gpt-4o)
NAMED_OPENAI_MODEL=gpt-4o

# Optional: Minimum confidence threshold for suggestions (default: 0.80)
NAMED_CONFIDENCE_THRESHOLD=0.80
